#include <stdio.h>

int board[20], n;

int isSafe(int row, int col)
{
    for(int i = 1; i < row; i++)
    {
        // Same column
        if(board[i] == col)
            return 0;

        // Same diagonal
        if((board[i] - col == i - row) ||
           (board[i] - col == row - i))
            return 0;
    }

    return 1;
}

void printSolution()
{
    printf("\nSolution:\n\n");

    for(int i = 1; i <= n; i++)
    {
        for(int j = 1; j <= n; j++)
        {
            if(board[i] == j)
                printf("Q ");
            else
                printf(". ");
        }
        printf("\n");
    }
}

void nQueens(int row)
{
    if(row > n)
    {
        printSolution();
        return;
    }

    for(int col = 1; col <= n; col++)
    {
        if(isSafe(row, col))
        {
            board[row] = col;
            nQueens(row + 1);
        }
    }
}

int main()
{
    printf("Enter number of queens: ");
    scanf("%d", &n);

    nQueens(1);

    return 0;
}
