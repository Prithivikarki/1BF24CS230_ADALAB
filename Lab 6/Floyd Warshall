#include <stdio.h>

#define INF 99999

void printSolution(int V, int dist[V][V])
{
    int i, j;

    printf("\nShortest Distance Matrix:\n");

    for(i = 0; i < V; i++)
    {
        for(j = 0; j < V; j++)
        {
            if(dist[i][j] == INF)
                printf("INF ");
            else
                printf("%3d ", dist[i][j]);
        }
        printf("\n");
    }
}

void floydWarshall(int V, int graph[V][V])
{
    int dist[V][V];
    int i, j, k;

    // Copy graph into dist matrix
    for(i = 0; i < V; i++)
    {
        for(j = 0; j < V; j++)
        {
            dist[i][j] = graph[i][j];
        }
    }

    // Floyd-Warshall Algorithm
    for(k = 0; k < V; k++)
    {
        for(i = 0; i < V; i++)
        {
            for(j = 0; j < V; j++)
            {
                if(dist[i][k] != INF &&
                   dist[k][j] != INF &&
                   dist[i][k] + dist[k][j] < dist[i][j])
                {
                    dist[i][j] = dist[i][k] + dist[k][j];
                }
            }
        }
    }

    printSolution(V, dist);
}

int main()
{
    int V;
    
    printf("Enter number of vertices: ");
    scanf("%d", &V);

    int graph[V][V];

    printf("Enter adjacency matrix:\n");
    printf("Use %d for INF (no edge)\n", INF);

    for(int i = 0; i < V; i++)
    {
        for(int j = 0; j < V; j++)
        {
            scanf("%d", &graph[i][j]);
        }
    }

    floydWarshall(V, graph);

    return 0;
}
